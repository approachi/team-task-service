# Скопируйте этот файл в .env и при желании поменяйте значения.
# docker compose и `make` читают .env автоматически.
#
# Это значения для локальной разработки, а не для прода — см.
# docs/COVER_LETTER.md, раздел "Секреты", про секрет-менеджер в проде.

DB_PASSWORD=app_password
MYSQL_ROOT_PASSWORD=root_password
JWT_SECRET=local-dev-secret-change-me
